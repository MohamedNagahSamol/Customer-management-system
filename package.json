{
  "name": "movie-vault-api",
  "version": "1.0.0",
  "description": "Movie Vault API — نظام إدارة أفلام مع مصادقة وقائمة مشاهدة. Movie management API with authentication, watchlist, and poster upload.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --detectOpenHandles",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --detectOpenHandles --coverage",
    "db:push": "node push-schema.js",
    "seed": "node prisma/seed.js",
    "test-db": "node test-db.js",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "movies",
    "api",
    "express",
    "prisma",
    "mariadb",
    "authentication",
    "jwt",
    "watchlist",
    "cloudinary",
    "helmet"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/node": "^25.6.0",
    "jest": "^30.4.2",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2"
  }
}
