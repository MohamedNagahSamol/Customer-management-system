<!DOCTYPE html>
<html lang="en" data-bs-theme="auto">
  <head>
    <script src="./js/color-modes.js"></script>
    <link rel="stylesheet" href="./bootstrap-icons-1.10.5/font/bootstrap-icons.min.css" />
    <link rel="icon" href="./img/favicon.svg" type="image/svg+xml">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="X-system Dashboard" />
    <title>Dashboard — X-system</title>

    <link href="./css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="./css/dark-light.css" />
    <link href="./css/sidebars.css" rel="stylesheet" />
    <link rel="stylesheet" href="./css/myStyle.css" />
    <style>
      .page-header {
        padding: 1.5rem 0 0.5rem;
      }
      .page-header h2 {
        font-weight: 700;
        font-size: 1.5rem;
      }
      .page-header p {
        color: var(--text-muted);
        font-size: 0.875rem;
      }
      .table-container {
        border-radius: 0.75rem;
        overflow: hidden;
      }
      .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-muted);
      }
      .empty-state i {
        font-size: 3rem;
        display: block;
        margin-bottom: 1rem;
        opacity: 0.4;
      }
    </style>
  </head>
  <body>
    <%- include('./Components/dark-light.ejs') %>

    <main class="d-flex flex-nowrap min-vh-100">
      <%- include('./Components/sidebar.ejs', {currentPage: "index"}) %>

      <section class="w-100 d-flex flex-column">
        <%- include('./Components/navbar.ejs') %>

        <div class="page-header d-flex justify-content-between align-items-center px-3 px-md-4">
          <div>
            <h2><i class="bi bi-grid-fill me-2 text-primary"></i>Dashboard</h2>
            <p>Manage and monitor your customer data</p>
          </div>
          <a href="/user/add.html" class="btn btn-primary btn-sm d-flex align-items-center gap-1">
            <i class="bi bi-plus-lg"></i> Add Customer
          </a>
        </div>

        <div class="px-3 px-md-4 flex-grow-1">
          <% if (arr.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h4>No data available</h4>
            <p class="text-muted">Get started by adding your first customer record.</p>
            <a href="/user/add.html" class="btn btn-primary mt-2">
              <i class="bi bi-plus-lg me-1"></i>Add Customer
            </a>
          </div>
          <% } %>

          <% if (arr.length > 0) { %>
          <div class="table-container border rounded-3 bg-white">
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th scope="col" style="width: 4%">#</th>
                  <th scope="col">Full Name</th>
                  <th scope="col">Gender</th>
                  <th scope="col">Country</th>
                  <th scope="col">Age</th>
                  <th scope="col">Last updated</th>
                  <th scope="col" style="width: 14%">Action</th>
                </tr>
              </thead>
              <tbody>
                <% arr.forEach((item, index) => { %>
                <tr>
                  <th scope="row" class="text-muted"><%= index + 1 %></th>
                  <td class="fw-medium"><%= item.firstName %> <%= item.lastName %></td>
                  <td><%= item.gender %></td>
                  <td><%= item.country %></td>
                  <td><%= item.age %></td>
                  <td class="text-muted small"><%= moment(item.updatedAt).fromNow(); %></td>
                  <td>
                    <div class="d-flex gap-1">
                      <a data-bs-toggle="tooltip" data-bs-title="View details" data-bs-placement="top"
                        class="btn btn-outline-primary btn-sm" href="/view/<%= item._id %>">
                        <i class="bi bi-eye"></i>
                      </a>
                      <a data-bs-toggle="tooltip" data-bs-title="Edit user" data-bs-placement="top"
                        class="btn btn-outline-secondary btn-sm" href="./edit/<%= item._id %>">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form style="display: inline;" action="/edit/<%= item._id %>?_method=DELETE" method="post">
                        <button data-bs-toggle="tooltip" data-bs-title="Delete user" data-bs-placement="top"
                          class="btn btn-outline-danger btn-sm">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>
      </section>
    </main>
    <script src="./js/bootstrap.bundle.min.js"></script>
    <script src="./js/sidebars.js"></script>
    <script src="./js/main.js"></script>
  </body>
</html>
