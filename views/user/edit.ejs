<!DOCTYPE html>
<html lang="en" data-bs-theme="auto">
  <head>
    <script src="../js/color-modes.js"></script>
    <link rel="stylesheet" href="../bootstrap-icons-1.10.5/font/bootstrap-icons.min.css" />
    <link rel="icon" href="../img/favicon.svg" type="image/svg+xml">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Edit customer — X-system" />
    <title>Edit Customer — X-system</title>

    <link href="../css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="../css/dark-light.css">
    <link href="../css/sidebars.css" rel="stylesheet" />
    <link rel="stylesheet" href="../css/myStyle.css" />
    <style>
      .form-card {
        background: var(--surface, #fff);
        border-radius: 0.75rem;
        border: 1px solid var(--border-light, #e2e8f0);
        padding: 2rem;
        max-width: 720px;
      }
      .detail-badge {
        font-size: 0.75rem;
        color: var(--text-muted, #64748b);
        background: var(--bg-subtle, #f8fafc);
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        border: 1px solid var(--border-light, #e2e8f0);
      }
    </style>
  </head>
  <body>
    <%- include('../Components/dark-light.ejs') %>

    <main class="d-flex flex-nowrap min-vh-100">
      <%- include('../Components/sidebar.ejs', {currentPage: "edit"}) %>

      <section class="w-100 d-flex flex-column">
        <%- include('../Components/navbar.ejs') %>

        <div class="p-3 p-md-4">
          <nav class="d-flex flex-wrap justify-content-between align-items-center mb-3" aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
              <li class="breadcrumb-item"><a href="/home">Home</a></li>
              <li class="breadcrumb-item active" aria-current="page"><%= obj.firstName %> <%= obj.lastName %></li>
            </ol>
            <span class="detail-badge">
              <i class="bi bi-hash"></i> <%= obj._id %>
            </span>
          </nav>

          <h2 class="fw-bold d-flex align-items-center gap-2 mb-1">
            <i class="bi bi-pencil-square text-primary"></i> Edit Customer
          </h2>
          <p class="text-muted" style="font-size: 0.875rem; margin-bottom: 1.5rem;">Update the customer's information below.</p>

          <div class="form-card">
            <form action="/edit/<%= obj._id %>?_method=PUT" method="post" class="row gx-3 gy-4">
              <div class="col-md-6">
                <label for="inputfirstName4" class="form-label">First Name</label>
                <input value="<%= obj.firstName %>" name="firstName" type="text" class="form-control" id="inputfirstName4" />
              </div>
              <div class="col-md-6">
                <label for="inputlastName4" class="form-label">Last Name</label>
                <input value="<%= obj.lastName %>" name="lastName" type="text" class="form-control" id="inputlastName4" />
              </div>
              <div class="col-md-6">
                <label for="inputemail4" class="form-label">Email</label>
                <input value="<%= obj.email %>" name="email" type="email" class="form-control" id="inputemail4" />
              </div>
              <div class="col-md-6">
                <label for="inputtele4" class="form-label">Telephone</label>
                <input value="<%= obj.phoneNumber %>" name="phoneNumber" type="tel" class="form-control" id="inputtele4" />
              </div>
              <div class="col-md-6">
                <label for="inputage4" class="form-label">Age</label>
                <input value="<%= obj.age %>" name="age" type="number" class="form-control" id="inputage4" />
              </div>
              <div class="col-md-6">
                <label for="inputCountry" class="form-label">Country</label>
                <select name="country" id="inputCountry" class="form-select">
                  <option selected hidden disabled>Choose a country</option>
                  <%- include('../Components/country_list.ejs', { selected: obj.country }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label for="inputGender" class="form-label">Gender</label>
                <select name="gender" id="inputGender" class="form-select">
                  <option selected hidden disabled>Select gender</option>
                  <option <%= "Male" === obj.gender ? "selected" : null %>>Male</option>
                  <option <%= "Female" === obj.gender ? "selected" : null %>>Female</option>
                </select>
              </div>
              <div class="col-12 pt-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                  <i class="bi bi-check-lg me-1"></i>Update Changes
                </button>
                <button data-bs-toggle="modal" data-bs-target="#exampleModal" type="button" class="btn btn-outline-danger px-4">
                  <i class="bi bi-trash me-1"></i>Delete Customer
                </button>
              </div>
            </form>
          </div>
        </div>
      </section>

      <!-- Modal -->
      <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title fw-semibold" id="exampleModalLabel">
                <i class="bi bi-exclamation-triangle text-danger me-2"></i>Delete Customer
              </h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
              <p class="mb-0">Are you sure you want to delete <strong><%= obj.firstName %> <%= obj.lastName %></strong>? This action cannot be undone.</p>
            </div>
            <div class="modal-footer border-top-0 pt-0">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <form action="/edit/<%= obj._id %>?_method=DELETE" method="post">
                <button type="submit" class="btn btn-danger px-4">
                  <i class="bi bi-trash me-1"></i>Delete
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>
    <script src="../js/bootstrap.bundle.min.js"></script>
    <script src="../js/sidebars.js"></script>
    <script src="../js/main.js"></script>
  </body>
</html>
