<!DOCTYPE html>
<html lang="en" data-bs-theme="auto">
  <head>
    <script src="../js/color-modes.js"></script>
    <link rel="stylesheet" href="../bootstrap-icons-1.10.5/font/bootstrap-icons.min.css" />
    <link rel="icon" href="../img/favicon.svg" type="image/svg+xml">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Customer details — X-system" />
    <title>Customer Details — X-system</title>

    <link href="../css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="../css/dark-light.css">
    <link href="../css/sidebars.css" rel="stylesheet" />
    <link rel="stylesheet" href="../css/myStyle.css" />
    <style>
      .detail-card {
        background: var(--surface, #fff);
        border-radius: 0.75rem;
        border: 1px solid var(--border-light, #e2e8f0);
        overflow: hidden;
        max-width: 720px;
      }
      .detail-label {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--text-muted, #64748b);
        min-width: 120px;
      }
      .detail-value {
        font-weight: 500;
        color: var(--text-primary, #1e293b);
      }
      .detail-row {
        padding: 0.875rem 1.5rem;
        border-bottom: 1px solid var(--border-light, #e2e8f0);
        display: flex;
        gap: 1rem;
      }
      .detail-row:last-child {
        border-bottom: none;
      }
      .detail-badge {
        font-size: 0.75rem;
        color: var(--text-muted, #64748b);
        background: var(--bg-subtle, #f8fafc);
        padding: 0.25rem 0.75rem;
        border-radius: 2rem;
        border: 1px solid var(--border-light, #e2e8f0);
      }
    </style>
  </head>
  <body>
    <%- include('../Components/dark-light.ejs') %>

    <main class="d-flex flex-nowrap min-vh-100">
      <%- include('../Components/sidebar.ejs', {currentPage: "view"}) %>

      <section class="w-100 d-flex flex-column">
        <%- include('../Components/navbar.ejs') %>

        <div class="p-3 p-md-4">
          <nav class="d-flex flex-wrap justify-content-between align-items-center mb-3" aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
              <li class="breadcrumb-item"><a href="/home">Home</a></li>
              <li class="breadcrumb-item active" aria-current="page"><%= obj.firstName %> <%= obj.lastName %></li>
            </ol>
            <span class="detail-badge">
              <i class="bi bi-hash"></i> <%= obj._id %>
            </span>
          </nav>

          <h2 class="fw-bold d-flex align-items-center gap-2 mb-1">
            <i class="bi bi-person-badge text-primary"></i> Customer Details
          </h2>
          <p class="text-muted" style="font-size: 0.875rem; margin-bottom: 1.5rem;">Viewing full information for this customer record.</p>

          <div class="detail-card">
            <div class="detail-row">
              <span class="detail-label">First Name</span>
              <span class="detail-value"><%= obj.firstName %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Last Name</span>
              <span class="detail-value"><%= obj.lastName %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Telephone</span>
              <span class="detail-value"><%= obj.phoneNumber %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Email</span>
              <span class="detail-value"><%= obj.email %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Gender</span>
              <span class="detail-value"><%= obj.gender %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Age</span>
              <span class="detail-value"><%= obj.age %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Country</span>
              <span class="detail-value"><%= obj.country %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Created on</span>
              <span class="detail-value"><%= moment(obj.createdAt).fromNow(); %></span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Last Update</span>
              <span class="detail-value"><%= moment(obj.updatedAt).fromNow(); %></span>
            </div>
          </div>

          <div class="mt-3 d-flex gap-2">
            <a href="/edit/<%= obj._id %>" class="btn btn-primary">
              <i class="bi bi-pencil me-1"></i>Edit Customer
            </a>
            <a href="/home" class="btn btn-outline-secondary">
              <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
            </a>
          </div>
        </div>
      </section>
    </main>
    <script src="../js/bootstrap.bundle.min.js"></script>
    <script src="../js/sidebars.js"></script>
    <script src="../js/main.js"></script>
  </body>
</html>
