<!DOCTYPE html>
<html lang="en" data-bs-theme="auto">
  <head>
    <script src="../js/color-modes.js"></script>
    <link rel="stylesheet" href="../bootstrap-icons-1.10.5/font/bootstrap-icons.min.css" />
    <link rel="icon" href="../img/favicon.svg" type="image/svg+xml">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Add new customer — X-system" />
    <title>Add Customer — X-system</title>

    <link href="../css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="../css/dark-light.css">
    <link href="../css/sidebars.css" rel="stylesheet" />
    <link rel="stylesheet" href="../css/myStyle.css" />
    <style>
      .form-card {
        background: var(--surface, #fff);
        border-radius: 0.75rem;
        border: 1px solid var(--border-light, #e2e8f0);
        padding: 2rem;
        max-width: 720px;
      }
      .page-title {
        font-weight: 700;
        font-size: 1.25rem;
        margin-bottom: 0.25rem;
      }
      .page-subtitle {
        color: var(--text-muted, #64748b);
        font-size: 0.875rem;
        margin-bottom: 1.5rem;
      }
    </style>
  </head>
  <body>
    <%- include('../Components/dark-light.ejs') %>

    <main class="d-flex flex-nowrap min-vh-100">
      <%- include('../Components/sidebar.ejs', {currentPage: "add"}) %>

      <section class="w-100 d-flex flex-column">
        <%- include('../Components/navbar.ejs') %>

        <div class="p-3 p-md-4">
          <h2 class="page-title d-flex align-items-center gap-2">
            <i class="bi bi-person-plus-fill text-primary"></i> Add Customer
          </h2>
          <p class="page-subtitle">Fill in the details below to add a new customer record.</p>

          <div class="form-card">
            <form action="/user/add.html" method="post" class="row gx-3 gy-4">
              <div class="col-md-6">
                <label for="inputfirstName4" class="form-label">First Name</label>
                <input name="firstName" placeholder="e.g. Ali" type="text" class="form-control" id="inputfirstName4" />
              </div>
              <div class="col-md-6">
                <label for="inputlastName4" class="form-label">Last Name</label>
                <input name="lastName" placeholder="e.g. Hassan" type="text" class="form-control" id="inputlastName4" />
              </div>
              <div class="col-md-6">
                <label for="inputemail4" class="form-label">Email</label>
                <input name="email" placeholder="ali@example.com" type="email" class="form-control" id="inputemail4" />
              </div>
              <div class="col-md-6">
                <label for="inputtele4" class="form-label">Telephone</label>
                <input name="phoneNumber" placeholder="011987899" type="tel" class="form-control" id="inputtele4" />
              </div>
              <div class="col-md-6">
                <label for="inputage4" class="form-label">Age</label>
                <input name="age" placeholder="Your age" type="number" class="form-control" id="inputage4" />
              </div>
              <div class="col-md-6">
                <label for="inputCountry" class="form-label">Country</label>
                <select name="country" id="inputCountry" class="form-select">
                  <option selected hidden disabled>Choose a country</option>
                  <%- include('../Components/country_list.ejs') %>
                </select>
              </div>
              <div class="col-md-6">
                <label for="inputGender" class="form-label">Gender</label>
                <select name="gender" id="inputGender" class="form-select">
                  <option selected hidden disabled>Select gender</option>
                  <option>Male</option>
                  <option>Female</option>
                </select>
              </div>
              <div class="col-12 pt-2">
                <button type="submit" class="btn btn-primary px-4">
                  <i class="bi bi-check-lg me-1"></i>Submit
                </button>
              </div>
            </form>
          </div>
        </div>
      </section>
    </main>
    <script src="../js/bootstrap.bundle.min.js"></script>
    <script src="../js/sidebars.js"></script>
    <script src="../js/main.js"></script>
  </body>
</html>
